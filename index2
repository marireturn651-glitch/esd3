// ═══════════════════ CORE LOGIC ═══════════════════
const MC = {EC:'var(--ec)',DSA:'var(--dsa)',OS:'var(--os)',MCU:'var(--mcu)'};
let uName='', uMod='ALL', qs=[], ans=[], choices={}, curQ=0, tmr=null, tLeft=0, tStart=0, dotFilter='ALL';

// ── Screen management ──
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>{
    s.classList.remove('active');
    s.style.display='none';
  });
  const el=document.getElementById(id);
  el.style.display=(id==='s-exam')?'grid':'flex';
  el.classList.add('active');
}

// ── Syntax highlight ──
function hl(code){
  return code
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/(\/\/[^\n]*)/g,'<span class="cmt">$1</span>')
    .replace(/(#\w+)/g,'<span class="pp">$1</span>')
    .replace(/\b(int|char|float|double|void|return|if|else|while|for|do|printf|scanf|struct|typedef|enum|switch|case|break|continue|default|unsigned|signed|static|extern|volatile|const|auto|register|sizeof|NULL)\b/g,'<span class="kw">$1</span>')
    .replace(/"([^"]*)"/g,'<span class="str">"$1"</span>')
    .replace(/\b(\d+(?:\.\d+)?)\b/g,'<span class="num">$1</span>');
}

// ── Fisher-Yates shuffle ──
function shuffle(arr){const a=[...arr];for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}

// ── LANDING ──
function initLanding(){
  const lb=JSON.parse(localStorage.getItem('cdac_lb_v5')||'[]');
  document.getElementById('kpi-attempts').textContent=lb.length;
}

document.getElementById('btn-proceed').addEventListener('click',()=>{
  const n=document.getElementById('inp-name').value.trim();
  if(!n){alert('Please enter your name first!');return;}
  uName=n; uMod=document.getElementById('inp-mod').value;
  showScreen('s-instr');
});

document.getElementById('btn-start').addEventListener('click',startExam);
document.getElementById('btn-prev').addEventListener('click',()=>navQ(-1));
document.getElementById('btn-next').addEventListener('click',()=>navQ(1));
document.getElementById('btn-skip').addEventListener('click',skipQ);
document.getElementById('btn-submit').addEventListener('click',confirmSubmit);
document.getElementById('btn-retry').addEventListener('click',()=>{showScreen('s-land');initLanding();});
document.getElementById('btn-home').addEventListener('click',()=>{showScreen('s-land');initLanding();});
document.getElementById('btn-clrlb').addEventListener('click',()=>{if(confirm('Clear leaderboard?')){localStorage.removeItem('cdac_lb_v5');renderLB();}});
document.querySelectorAll('.mf-btn').forEach(b=>b.addEventListener('click',()=>filterDots(b.dataset.m)));

function startExam(){
  qs = uMod==='ALL' ? shuffle(BANK) : shuffle(BANK.filter(q=>q.m===uMod));
  // Randomize answer positions
  qs = qs.map(q=>{
    const shuffledOpts=shuffle(q.o);
    const correct=q.o[q.a]; // get the correct answer text
    return {...q, o:shuffledOpts, a:shuffledOpts.indexOf(correct)};
  });
  ans=new Array(qs.length).fill(null); // null=unanswered
  choices={};
  curQ=0;
  tLeft=(uMod==='ALL'?90:30)*60;
  tStart=Date.now();
  document.getElementById('qn-tot').textContent=qs.length;
  showScreen('s-exam');
  renderSidebar();
  renderQ(0);
  startTimer();
}

// ── TIMER ──
function startTimer(){
  clearInterval(tmr);
  tmr=setInterval(()=>{
    tLeft--;
    const m=String(Math.floor(tLeft/60)).padStart(2,'0');
    const s=String(tLeft%60).padStart(2,'0');
    const el=document.getElementById('timer');
    el.textContent=`${m}:${s}`;
    el.className='timer'+(tLeft<=120?' danger':tLeft<=300?' warn':'');
    if(tLeft<=0){clearInterval(tmr);doSubmit();}
  },1000);
}

// ── RENDER QUESTION ──
function renderQ(idx){
  curQ=idx;
  const q=qs[idx];
  document.getElementById('qn-cur').textContent=idx+1;
  const mb=document.getElementById('qn-mod');
  mb.textContent=q.m;
  mb.style.background=MC[q.m]+'22';
  mb.style.color=MC[q.m];
  mb.style.border=`1.5px solid ${MC[q.m]}44`;

  const isAnswered = ans[idx]!==null && ans[idx]!=='skipped';
  const labels=['A','B','C','D'];

  let html=`<div class="q-header">
    <span class="q-badge" style="color:${MC[q.m]};border-color:${MC[q.m]}33">${q.m} · Q${idx+1}</span>
  </div>
  <div class="q-text">${q.q.replace(/\n/g,'<br>')}</div>`;

  if(q.code) html+=`<pre class="code">${hl(q.code)}</pre>`;

  html+=`<div class="opts">`;
  q.o.forEach((opt,oi)=>{
    let cls='opt';
    if(isAnswered){
      if(oi===q.a) cls+=' correct reveal';
      else if(choices[idx]===oi) cls+=' wrong';
      cls+=' disabled';
    }
    html+=`<div class="${cls}" onclick="answerQ(${idx},${oi})">
      <div class="opt-circle">${labels[oi]}</div>
      <div>${opt}</div>
    </div>`;
  });
  html+=`</div>`;

  if(isAnswered){
    html+=`<div class="explanation">
      <div class="exp-title">💡 ${q.tip}</div>
      ${q.e}
    </div>`;
  }

  document.getElementById('q-body').innerHTML=html;
  document.getElementById('q-body').scrollTop=0;
  updateDots();
  updateProgress();
}

function answerQ(idx,chosen){
  if(ans[idx]!==null && ans[idx]!=='skipped') return;
  choices[idx]=chosen;
  ans[idx]=(chosen===qs[idx].a)?'correct':'wrong';
  updateScore();
  renderQ(idx);
}

function skipQ(){
  if(ans[curQ]===null) ans[curQ]='skipped';
  navQ(1);
}

function navQ(dir){
  let n=curQ+dir;
  if(n<0)n=0;
  if(n>=qs.length)n=qs.length-1;
  renderQ(n);
}

function updateScore(){
  const sc=ans.filter(a=>a==='correct').length;
  document.getElementById('score-live').textContent=sc;
}

// ── SIDEBAR ──
function renderSidebar(){
  dotFilter='ALL';
  document.querySelector('.mf-btn[data-m="ALL"]').classList.add('active');
  updateDots();
  updateProgress();
}

function filterDots(m){
  dotFilter=m;
  document.querySelectorAll('.mf-btn').forEach(b=>b.classList.toggle('active',b.dataset.m===m));
  updateDots();
}

function updateDots(){
  const grid=document.getElementById('dot-grid');
  let html='';
  qs.forEach((q,i)=>{
    const show=(dotFilter==='ALL'||q.m===dotFilter);
    let cls='dot';
    if(!show) cls+=' hide';
    else if(i===curQ) cls+=' cur';
    else if(ans[i]==='correct') cls+=' ok';
    else if(ans[i]==='wrong') cls+=' ng';
    else if(ans[i]==='skipped') cls+=' sk';
    html+=`<div class="${cls}" onclick="renderQ(${i})" title="Q${i+1} (${q.m})">${i+1}</div>`;
  });
  grid.innerHTML=html;
}

function updateProgress(){
  const mods=['EC','DSA','OS','MCU'];
  const active=qs.map((q,i)=>({q,i})).filter(({q})=>qs.length&&true);
  let html='';
  mods.forEach(m=>{
    const idx=qs.map((_,i)=>i).filter(i=>qs[i].m===m);
    if(!idx.length)return;
    const c=idx.filter(i=>ans[i]==='correct').length;
    const pct=Math.round(c/idx.length*100);
    html+=`<div class="pr">
      <span class="pr-lbl" style="color:${MC[m]}">${m}</span>
      <div class="pr-bar"><div class="pr-fill" style="width:${pct}%;background:${MC[m]}"></div></div>
      <span class="pr-num">${c}/${idx.length}</span>
    </div>`;
  });
  document.getElementById('prog-rows').innerHTML=html;
}

// ── SUBMIT ──
function confirmSubmit(){
  const unan=ans.filter(a=>a===null).length;
  if(unan>0){if(!confirm(`${unan} question(s) unanswered. Submit anyway?`))return;}
  doSubmit();
}

function doSubmit(){
  clearInterval(tmr);
  ans.forEach((_,i)=>{if(ans[i]===null)ans[i]='skipped';});
  const used=(uMod==='ALL'?90:30)*60-tLeft;
  showResult(used);
}

// ── RESULT ──
function showResult(timeTaken){
  const correct=ans.filter(a=>a==='correct').length;
  const wrong=ans.filter(a=>a==='wrong').length;
  const skipped=ans.filter(a=>a==='skipped').length;
  const total=qs.length;
  const pct=Math.round(correct/total*100);

  let emoji,msg;
  if(pct>=90){emoji='🏆';msg='Outstanding! You are CDAC CCE ready!';}
  else if(pct>=75){emoji='🥇';msg='Excellent! Great performance!';}
  else if(pct>=60){emoji='👍';msg='Good work! Keep practicing!';}
  else if(pct>=40){emoji='📖';msg='Keep studying — you can improve!';}
  else{emoji='💪';msg='More practice needed. Review each topic!';}

  document.getElementById('r-emoji').textContent=emoji;
  document.getElementById('r-pct').textContent=pct+'%';
  document.getElementById('r-msg').textContent=msg;
  document.getElementById('r-correct').textContent=correct;
  document.getElementById('r-wrong').textContent=wrong;
  document.getElementById('r-skip').textContent=skipped;
  const mm=Math.floor(timeTaken/60), ss=timeTaken%60;
  document.getElementById('r-time').textContent=`${mm}m${ss}s`;

  // Module breakdown
  const mods=['EC','DSA','OS','MCU'];
  let bh='<h3>📊 Module-wise Breakdown</h3>';
  mods.forEach(m=>{
    const idx=qs.map((_,i)=>i).filter(i=>qs[i].m===m);
    if(!idx.length)return;
    const c=idx.filter(i=>ans[i]==='correct').length;
    const p=Math.round(c/idx.length*100);
    bh+=`<div class="mb-row">
      <div class="mb-top"><span style="color:${MC[m]}">${m} — ${qs.filter(q=>q.m===m).length} Questions</span><span>${c}/${idx.length} · ${p}%</span></div>
      <div class="mb-bar"><div class="mb-fill" style="width:${p}%;background:${MC[m]}"></div></div>
    </div>`;
  });
  document.getElementById('r-breakdown').innerHTML=bh;

  // Save & render leaderboard
  saveLB(correct,total,pct,timeTaken);
  renderLB();

  showScreen('s-result');
  if(pct>=70) confetti();
}

// ── LEADERBOARD ──
function saveLB(score,total,pct,time){
  let lb=JSON.parse(localStorage.getItem('cdac_lb_v5')||'[]');
  lb.push({name:uName,score,total,pct,time,mod:uMod,date:new Date().toLocaleDateString('en-IN')});
  lb.sort((a,b)=>b.pct-a.pct||a.time-b.time);
  lb=lb.slice(0,50);
  localStorage.setItem('cdac_lb_v5',JSON.stringify(lb));
}

function renderLB(){
  let lb=JSON.parse(localStorage.getItem('cdac_lb_v5')||'[]');
  if(!lb.length){
    document.getElementById('r-lb').innerHTML='<h3>🏆 Leaderboard</h3><p style="color:var(--txt3);font-size:.85rem;margin-top:.5rem">No attempts yet. Be the first!</p>';
    return;
  }
  const colors=['#4f9eff','#2ecc71','#f1c40f','#9b59b6','#e67e22','#e74c3c'];
  const medals=['🥇','🥈','🥉'];
  const top3=lb.slice(0,3);

  // Podium (2nd, 1st, 3rd order)
  const podOrder=[top3[1],top3[0],top3[2]];
  const podHeights=[35,55,20];
  let ph='<div class="podium">';
  podOrder.forEach((e,pi)=>{
    if(!e){ph+=`<div class="pod-slot"></div>`;return;}
    const rank=lb.indexOf(e);
    const av=e.name.charAt(0).toUpperCase();
    const col=colors[rank%6];
    ph+=`<div class="pod-slot">
      <span class="pod-medal">${medals[rank]||''}</span>
      <div class="pod-av" style="background:${col};border-color:${col}">${av}</div>
      <div class="pod-name">${e.name}</div>
      <div class="pod-pct">${e.pct}% · ${e.score}/${e.total}</div>
      <div class="pod-base" style="height:${podHeights[pi]}px;background:${col}33;border-top:2px solid ${col}"></div>
    </div>`;
  });
  ph+='</div>';

  let th=`<table class="lb-table"><thead><tr><th>#</th><th>Name</th><th>Score</th><th>%</th><th>Module</th><th>Date</th></tr></thead><tbody>`;
  lb.forEach((e,i)=>{
    const isYou=(e.name===uName);
    th+=`<tr class="${isYou?'you':''}"><td>${i+1}</td><td>${e.name}${isYou?'<span class="you-tag">YOU</span>':''}</td><td>${e.score}/${e.total}</td><td>${e.pct}%</td><td>${e.mod}</td><td>${e.date}</td></tr>`;
  });
  th+=`</tbody></table>`;

  document.getElementById('r-lb').innerHTML='<h3>🏆 Leaderboard</h3>'+ph+th;
}

// ── CONFETTI ──
function confetti(){
  const cols=['#4f9eff','#2ecc71','#f1c40f','#9b59b6','#e67e22','#e74c3c','#fff'];
  for(let i=0;i<100;i++){
    const el=document.createElement('div');
    el.className='cf';
    const size=6+Math.random()*8;
    el.style.cssText=`left:${Math.random()*100}vw;top:-20px;width:${size}px;height:${size}px;background:${cols[i%cols.length]};animation-duration:${2.5+Math.random()*3}s;animation-delay:${Math.random()*2.5}s;transform:rotate(${Math.random()*360}deg)`;
    document.body.appendChild(el);
    setTimeout(()=>el.remove(),7000);
  }
}

// ── KEYBOARD ──
document.addEventListener('keydown',e=>{
  if(!document.getElementById('s-exam').classList.contains('active'))return;
  if(e.key==='ArrowRight')navQ(1);
  else if(e.key==='ArrowLeft')navQ(-1);
  else if(['1','2','3','4'].includes(e.key)){
    const i=parseInt(e.key)-1;
    if(ans[curQ]===null||ans[curQ]==='skipped')answerQ(curQ,i);
  }
});

// Init
initLanding();
</script>
