<style>
:root{
  --bg:#080c14;--s1:#0e1421;--s2:#141c2e;--s3:#1a2438;
  --b1:#1e2d47;--b2:#243352;--border:#2a3f5f;--border2:#3a5070;
  --acc:#4f9eff;--acc2:#2d7de8;--grn:#2ecc71;--grn2:#27ae60;
  --red:#e74c3c;--red2:#c0392b;--ylw:#f1c40f;--pur:#9b59b6;--org:#e67e22;
