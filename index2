const BANK = [
// ── EMBEDDED C (50) ──
{m:"EC",q:"What is the output?\nint x = 5;\nprintf(\"%d\", x++);",code:"int x = 5;\nprintf(\"%d\", x++);",o:["5","6","4","Undefined"],a:0,tip:"Post-increment",e:"x++ is post-increment: returns current value (5) first, then increments x to 6. So printf prints 5."},
{m:"EC",q:"Which storage class variable persists for the program lifetime but has file scope only?",o:["auto","extern","static (global)","register"],a:2,tip:"static global",e:"A static global variable has file scope (not visible outside the file) but lives for the entire program duration."},
{m:"EC",q:"What does malloc(0) return?",o:["Always NULL","NULL or unique non-NULL pointer (implementation-defined)","Always a valid pointer","Crash"],a:1,tip:"malloc(0) edge case",e:"C standard says malloc(0) may return NULL or a non-NULL unique pointer that must not be dereferenced. It is implementation-defined."},
{m:"EC",q:"What is the size of any pointer on a 64-bit system?",o:["4 bytes","2 bytes","8 bytes","Depends on pointed type"],a:2,tip:"Pointer size on 64-bit",e:"On 64-bit systems, all pointer types (int*, char*, void*) are 8 bytes, since memory addresses are 64-bit wide."},
{m:"EC",q:"What is the output?\nint a[] = {1,2,3};\nprintf(\"%d\", *(a+1));",code:"int a[] = {1,2,3};\nprintf(\"%d\", *(a+1));",o:["1","2","3","Address of a[1]"],a:1,tip:"Pointer arithmetic on array",e:"a decays to pointer to first element. a+1 points to a[1]=2. Dereferencing gives 2."},
{m:"EC",q:"Which correctly declares a pointer to a function taking int and returning int?",o:["int *fp(int)","int (*fp)(int)","int *(fp)(int)","(int*)fp(int)"],a:1,tip:"Function pointer syntax",e:"int (*fp)(int) — the parentheses around *fp bind first, making fp a pointer to a function. Without them, int *fp(int) declares a function returning int*."},
{m:"EC",q:"What does 'volatile' tell the compiler?",o:["Store in register","Do not optimize accesses — value may change unexpectedly","Make it constant","Allocate on heap"],a:1,tip:"volatile keyword",e:"volatile prevents the compiler from caching/optimizing reads and writes. Used for hardware registers and ISR-shared variables."},
{m:"EC",q:"What is the result of: 5 & 3?",o:["1","7","2","15"],a:0,tip:"Bitwise AND",e:"5=0101, 3=0011. AND=0001=1."},
{m:"EC",q:"calloc() differs from malloc() because calloc():",o:["Is faster","Zero-initializes the allocated memory","Takes one argument","Allocates on stack"],a:1,tip:"calloc vs malloc",e:"calloc(n,size) allocates n*size bytes AND zeroes them all. malloc() allocates but does NOT initialize memory."},
{m:"EC",q:"What is a dangling pointer?",o:["NULL pointer","Pointer to already-freed memory","void pointer","Pointer to local variable after return"],a:1,tip:"Dangling pointer",e:"A dangling pointer points to memory that was freed via free(). Dereferencing it is undefined behavior and a common bug."},
{m:"EC",q:"What is sizeof('A') in C (not C++)?",o:["1","2","4","8"],a:2,tip:"Character literal type in C",e:"In C, character literals like 'A' have type int, not char. So sizeof('A') = sizeof(int) = 4."},
{m:"EC",q:"What is the output?\nint x=10;\nif(x=0) printf(\"zero\");\nelse printf(\"nonzero\");",code:"int x=10;\nif(x=0) printf(\"zero\");\nelse printf(\"nonzero\");",o:["zero","nonzero","Compile error","Nothing"],a:1,tip:"Assignment inside if",e:"x=0 is an assignment (not ==). It assigns 0 to x and evaluates to 0 (false). So else branch runs → prints 'nonzero'."},
{m:"EC",q:"Which header provides malloc, calloc, free?",o:["<string.h>","<stdio.h>","<stdlib.h>","<alloc.h>"],a:2,tip:"stdlib.h",e:"Dynamic memory functions (malloc, calloc, realloc, free) are declared in <stdlib.h>."},
{m:"EC",q:"What is the output?\nint x=7; printf(\"%d\", x&(x-1));",code:"int x=7; printf(\"%d\", x&(x-1));",o:["7","6","0","1"],a:1,tip:"Clear lowest set bit trick",e:"x=7=0111, x-1=6=0110. AND=0110=6. This trick clears the lowest set bit of x."},
{m:"EC",q:"What does 'extern' keyword mean?",o:["Variable is local","Variable/function defined in another translation unit","Variable is constant","Variable is on stack"],a:1,tip:"extern keyword",e:"extern tells the compiler: this variable/function exists but is defined in a different file. No memory is allocated here."},
{m:"EC",q:"What is the output?\nint a=2,b=3; printf(\"%d\",a<<b);",code:"int a=2,b=3; printf(\"%d\",a<<b);",o:["6","8","16","24"],a:2,tip:"Left shift = multiply by 2^n",e:"a<<b = 2<<3 = 2×2³ = 2×8 = 16."},
{m:"EC",q:"Which preprocessor directive prevents multiple inclusion of a header?",o:["#once","#include_guard","#ifndef HEADER_H / #define / #endif","#protect"],a:2,tip:"Header guard",e:"Standard include guard: #ifndef HEADER_H / #define HEADER_H / ... / #endif. Also #pragma once works on most compilers."},
{m:"EC",q:"What is the output?\nprintf(\"%d\", 10/3);",code:"printf(\"%d\", 10/3);",o:["3.33","3","4","Error"],a:1,tip:"Integer division truncates",e:"In C, dividing two integers truncates towards zero. 10/3 = 3 (remainder 1 is discarded)."},
{m:"EC",q:"What is a double pointer (int **pp)?",o:["Pointer to float","Pointer to a pointer to int","Two separate pointers","Double-precision pointer"],a:1,tip:"Double pointer",e:"int **pp holds the address of an int*. Used for dynamic 2D arrays, output parameters in functions, etc."},
{m:"EC",q:"What is the output?\nint a=5,b=10; printf(\"%d\", a>b?a:b);",code:"int a=5,b=10; printf(\"%d\", a>b?a:b);",o:["5","10","1","0"],a:1,tip:"Ternary operator",e:"5>10 is false, so ternary returns b=10."},
{m:"EC",q:"'register' storage class hints the compiler to:",o:["Store on heap","Store in CPU register for fast access","Store in ROM","Make read-only"],a:1,tip:"register hint",e:"register suggests the compiler keep the variable in a CPU register. Modern compilers often ignore this, as they optimize automatically."},
{m:"EC",q:"What does the 'const' qualifier do?",o:["Zero-initialize the variable","Prevent modification after initialization","Allocate in ROM always","Speed up execution"],a:1,tip:"const qualifier",e:"const makes a variable read-only at compile level — any attempt to modify it produces a compile error."},
{m:"EC",q:"What is the output of: printf(\"%d\", !0);",code:"printf(\"%d\", !0);",o:["0","1","-1","Undefined"],a:1,tip:"Logical NOT",e:"!0 = logical NOT of false = 1 (true in C). printf prints 1."},
{m:"EC",q:"In C, what is a union?",o:["Like struct but all members at different addresses","All members share the same memory location","Array of different types","Pointer to struct"],a:1,tip:"union",e:"A union allocates memory equal to its largest member. All members overlap at the same address — only one can be used at a time."},
{m:"EC",q:"What is the output? (switch fall-through)\nint x=1;\nswitch(x){\ncase 1:printf(\"A\");\ncase 2:printf(\"B\");\ndefault:printf(\"C\");}",code:"int x=1;\nswitch(x){\ncase 1:printf(\"A\");\ncase 2:printf(\"B\");\ndefault:printf(\"C\");}",o:["A","AB","ABC","A then stop"],a:2,tip:"Switch fall-through without break",e:"Without break, execution falls through ALL subsequent cases. case 1 matches → prints A, falls to case 2 → B, falls to default → C. Output: ABC."},
{m:"EC",q:"What is the result of: 7 ^ 5?",o:["3","12","2","1"],a:2,tip:"Bitwise XOR",e:"7=0111, 5=0101. XOR=0010=2."},
{m:"EC",q:"Which function reads a line including spaces from stdin?",o:["scanf(\"%s\")","gets()","fgets()","getword()"],a:2,tip:"fgets for safe line input",e:"fgets(buf,size,stdin) reads up to size-1 chars including spaces safely. scanf(\"%s\") stops at whitespace. gets() is unsafe (buffer overflow risk)."},
{m:"EC",q:"What does 'typedef unsigned int uint;' do?",o:["Creates new type","Creates alias 'uint' for 'unsigned int'","Replaces unsigned int everywhere","Makes uint constant"],a:1,tip:"typedef creates alias",e:"typedef creates a synonym/alias for an existing type. uint becomes interchangeable with unsigned int."},
{m:"EC",q:"In GDB, which command sets a breakpoint at line 20?",o:["stop 20","break 20","pause 20","mark 20"],a:1,tip:"GDB breakpoint",e:"In GDB: 'break 20' or 'b 20' sets a breakpoint at line 20. Other useful commands: run, next(n), step(s), continue(c), print(p)."},
{m:"EC",q:"When an array is passed to a function in C:",o:["Array is fully copied","Pointer to first element is passed","Array length is automatically passed","Error — arrays can't be passed"],a:1,tip:"Array decay to pointer",e:"Arrays decay to a pointer to their first element when passed. The function receives a pointer, not a copy of the array."},
{m:"EC",q:"What is the output?\nchar *s=\"hello\";\nprintf(\"%c\",*(s+2));",code:"char *s=\"hello\";\nprintf(\"%c\",*(s+2));",o:["h","e","l","o"],a:2,tip:"String pointer indexing",e:"s points to 'h'. s+2 points to 3rd char 'l'. Dereferencing gives 'l'."},
{m:"EC",q:"String literals in C are stored in:",o:["Stack","Heap","Read-only data segment","BSS segment"],a:2,tip:"String literal storage",e:"String literals like \"hello\" are in the read-only data segment. Attempting to modify them causes undefined behavior (often segfault)."},
{m:"EC",q:"Which fopen mode opens a file for writing (creates if not exists)?",o:["\"r\"","\"w\"","\"a\"","\"x\""],a:1,tip:"fopen modes",e:"\"w\" opens/creates a file for writing (truncates if exists). \"r\"=read, \"a\"=append, \"r+\"=read+write."},
{m:"EC",q:"What is the value of x after: int x=5; x>>=1;",code:"int x=5; x>>=1;",o:["10","4","2","1"],a:2,tip:"Right shift arithmetic",e:"x>>=1 means x = x>>1 = 5>>1 = 2 (5/2 integer division = 2, since 5=0101 >> 1 = 0010 = 2)."},
{m:"EC",q:"What is the output?\nint arr[3]={0};\nprintf(\"%d %d\",arr[0],arr[2]);",code:"int arr[3]={0};\nprintf(\"%d %d\",arr[0],arr[2]);",o:["0 0","Garbage Garbage","0 Garbage","Compile error"],a:0,tip:"Array zero initialization",e:"Initializing with {0} sets first element to 0 and zero-initializes all remaining elements. Both arr[0] and arr[2] = 0."},
{m:"EC",q:"What is enum used for in C?",o:["Dynamic allocation","Named integer constants","String enumeration","Pointer types"],a:1,tip:"enum for named constants",e:"enum { RED=0, GREEN=1, BLUE=2 } defines named integer constants, making code more readable than magic numbers."},
{m:"EC",q:"What is argc in main(int argc, char *argv[])?",o:["Array of argument strings","Count of command-line arguments (including program name)","Size of argv buffer","Index of first argument"],a:1,tip:"argc = argument count",e:"argc is the count of command-line arguments. argv[0] is the program name, argv[1] is first argument, etc."},
{m:"EC",q:"What is the output?\nchar c='A';\nprintf(\"%d\",c);",code:"char c='A';\nprintf(\"%d\",c);",o:["A","65","1","Error"],a:1,tip:"char as integer, ASCII",e:"'A' has ASCII value 65. %d format prints the integer value of c, which is 65."},
{m:"EC",q:"What is recursion?",o:["Loop without condition","A function that calls itself","Multiple return values","Goto statement"],a:1,tip:"Recursion",e:"Recursion = a function calling itself. Must have a base case to terminate. Stack space grows with each call."},
{m:"EC",q:"What is the output of sizeof(int[5])?",code:"sizeof(int[5])",o:["5","10","20","4"],a:2,tip:"sizeof array",e:"sizeof(int)=4 on typical system. sizeof(int[5]) = 5×4 = 20 bytes."},
{m:"EC",q:"Which is the correct way to free dynamically allocated memory?",o:["delete ptr","free(ptr)","dealloc(ptr)","release(ptr)"],a:1,tip:"free() from stdlib.h",e:"free(ptr) from <stdlib.h> releases memory allocated by malloc/calloc/realloc. Does NOT set ptr to NULL — you must do that manually to avoid dangling pointer."},
{m:"EC",q:"#define PI 3.14 — what does this do?",o:["Declares float variable PI","Creates textual substitution macro PI→3.14","Creates typed constant","Reserves memory for PI"],a:1,tip:"#define macro = textual substitution",e:"#define is a preprocessor directive creating a textual substitution. Every PI in source code is replaced with 3.14 before compilation."},
{m:"EC",q:"What does the Makefile tool do?",o:["Compiles only one file","Automates build process — tracks dependencies and recompiles only changed files","Links object files manually","Runs test cases"],a:1,tip:"Makefile build automation",e:"Make reads the Makefile, checks timestamps, and only recompiles files that changed or whose dependencies changed. Automates the full build pipeline."},
{m:"EC",q:"What is the output? int x=0; while(x<3){printf(\"%d \",x++);}",code:"int x=0; while(x<3){printf(\"%d \",x++);}",o:["0 1 2","1 2 3","0 1 2 3","Infinite loop"],a:0,tip:"while loop with post-increment",e:"Loop runs for x=0,1,2 (exits when x=3). printf uses post-increment so prints 0,1,2 then x becomes 1,2,3. Output: 0 1 2."},
{m:"EC",q:"What is a bit-field in a struct?",o:["Array of bits","Struct member with specified number of bits","Bitwise pointer","Bit-level array"],a:1,tip:"Bit-fields",e:"struct { unsigned int flag:1; unsigned int mode:3; } uses bit-fields to pack data into specified bit widths. Saves memory in embedded systems."},
{m:"EC",q:"Which Linux command compiles a C file with GCC?",o:["cc file.c","gcc file.c -o output","make file.c","ld file.c"],a:1,tip:"GCC compilation",e:"gcc file.c -o output compiles file.c and produces executable 'output'. -Wall adds warnings, -g adds debug info."},
{m:"EC",q:"What is the output? int x=5; printf(\"%d %d\",x,++x);",code:"int x=5; printf(\"%d %d\",x,++x);",o:["5 6","6 6","5 5","Undefined behavior"],a:3,tip:"Undefined behavior: order of evaluation",e:"Modifying x (++x) and reading x in the same expression without sequence point is undefined behavior in C. The output is unpredictable."},

// ── DSA (50) ──
{m:"DSA",q:"What is the time complexity of binary search?",o:["O(n)","O(log n)","O(n log n)","O(1)"],a:1,tip:"Binary search = O(log n)",e:"Binary search halves the search space each step. Recurrence T(n)=T(n/2)+1 solves to O(log n)."},
{m:"DSA",q:"Which data structure uses LIFO order?",o:["Queue","Stack","Circular Queue","Priority Queue"],a:1,tip:"LIFO = Stack",e:"Stack is Last-In-First-Out. push() adds to top, pop() removes from top. Used in recursion, undo operations, expression evaluation."},
{m:"DSA",q:"Time complexity of inserting at the beginning of a singly linked list?",o:["O(n)","O(log n)","O(1)","O(n²)"],a:2,tip:"Head insertion = O(1)",e:"Inserting at head only requires updating the head pointer — O(1) regardless of list size."},
{m:"DSA",q:"Which sorting algorithm always has O(n log n) worst case?",o:["Bubble sort","Quick sort","Merge sort","Selection sort"],a:2,tip:"Merge sort: always O(n log n)",e:"Merge sort always divides and merges in O(n log n). Quick sort degrades to O(n²) with bad pivot choice."},
{m:"DSA",q:"In a Binary Search Tree (BST), where is the minimum element?",o:["Root","Rightmost node","Leftmost node","Any leaf"],a:2,tip:"BST minimum = leftmost",e:"BST property: all left children < parent. The minimum is found by going left until there is no left child."},
{m:"DSA",q:"What is the space complexity of naive recursive Fibonacci?",o:["O(1)","O(n)","O(log n)","O(2ⁿ)"],a:1,tip:"Recursion stack depth",e:"The call stack depth at maximum is O(n) for fib(n). Space complexity = O(n) due to stack frames."},
{m:"DSA",q:"What is a circular queue's main advantage?",o:["Faster search","Reuses freed front space — no 'false full' problem","Less memory than array","Simpler implementation"],a:1,tip:"Circular queue reuses space",e:"In a linear queue, dequeued front spaces are wasted. Circular queue wraps rear pointer around, reusing those spaces."},
{m:"DSA",q:"Which data structure does BFS (Breadth-First Search) use?",o:["Stack","Queue","Priority Queue","Deque"],a:1,tip:"BFS uses Queue (FIFO)",e:"BFS explores level by level. FIFO queue ensures nodes are processed in discovery order."},
{m:"DSA",q:"Quick sort worst-case time complexity?",o:["O(n log n)","O(n)","O(n²)","O(log n)"],a:2,tip:"Quick sort worst = O(n²)",e:"Worst case: pivot always smallest/largest (e.g., sorted array with first element as pivot) → O(n²). Average = O(n log n)."},
{m:"DSA",q:"In hashing, what is a 'collision'?",o:["Two identical keys","Two different keys hash to same index","Hash table is full","Key not found"],a:1,tip:"Hash collision",e:"Collision: different keys produce the same hash index. Resolved by chaining (linked lists) or open addressing (probing)."},
{m:"DSA",q:"What is the height of a balanced AVL tree with n nodes?",o:["O(n)","O(log n)","O(√n)","O(n²)"],a:1,tip:"AVL tree height = O(log n)",e:"AVL trees enforce balance factor ≤ 1. This guarantees height = O(log n), ensuring O(log n) search/insert/delete."},
{m:"DSA",q:"Time complexity of accessing an element in an array by index?",o:["O(n)","O(log n)","O(1)","O(n²)"],a:2,tip:"Array random access = O(1)",e:"Array element is at base_addr + index × element_size — direct computation, no traversal needed. O(1)."},
{m:"DSA",q:"What extra pointer does a doubly linked list node have vs singly linked?",o:["Next","Previous","Head","Tail"],a:1,tip:"DLL has 'prev' pointer",e:"DLL node has both 'next' and 'prev' pointers, enabling traversal in both directions. Singly linked list has only 'next'."},
{m:"DSA",q:"Which collision resolution uses linked lists at each bucket?",o:["Linear probing","Quadratic probing","Separate chaining","Double hashing"],a:2,tip:"Separate chaining = linked lists",e:"In separate chaining, each hash table slot holds a linked list of all keys that hash to it. Simple and handles high load factors well."},
{m:"DSA",q:"Time complexity of heap sort?",o:["O(n)","O(n log n)","O(n²)","O(log n)"],a:1,tip:"Heap sort = O(n log n)",e:"Build heap: O(n). Extract max n times × O(log n) each = O(n log n) total."},
{m:"DSA",q:"What distinguishes a Red-Black tree from a plain BST?",o:["Faster search only","Self-balancing via node coloring rules ensuring O(log n) height","No duplicate keys","Alphabetical ordering"],a:1,tip:"Red-Black = self-balancing BST",e:"Red-Black tree colors nodes red/black with rules (root=black, no red-red parent-child, equal black height all paths) ensuring O(log n) height."},
{m:"DSA",q:"What does 'enqueue' do in a queue?",o:["Remove from front","Add to rear","Add to front","Remove from rear"],a:1,tip:"Queue: enqueue = add to rear",e:"Queue is FIFO. enqueue adds to rear (back). dequeue removes from front. Both O(1)."},
{m:"DSA",q:"Best-case time complexity of bubble sort (on sorted array with optimization)?",o:["O(n²)","O(n log n)","O(n)","O(1)"],a:2,tip:"Optimized bubble sort best case = O(n)",e:"With a 'swapped' flag: if no swaps occur in a pass, array is sorted. On already-sorted input → one pass, O(n)."},
{m:"DSA",q:"What is an ADT (Abstract Data Type)?",o:["Data type with fixed implementation","Data type defined by its operations and behavior, not implementation","Hardware-specific type","Compiler-generated type"],a:1,tip:"ADT = behavior without implementation",e:"ADT specifies WHAT operations are available and their behavior, independent of HOW they are implemented. Stack ADT: push, pop, peek, isEmpty."},
{m:"DSA",q:"Pushing to a full array-based stack causes:",o:["Stack underflow","Stack overflow","Segmentation fault","Automatic resize"],a:1,tip:"Stack overflow",e:"Stack overflow = attempt to push when stack is full. Stack underflow = attempt to pop from empty stack."},
{m:"DSA",q:"In-order traversal of a BST produces:",o:["Random order","Ascending sorted order","Descending order","Breadth-first order"],a:1,tip:"BST in-order = sorted",e:"In-order (Left → Root → Right) visits BST nodes in ascending key order. Useful for sorting."},
{m:"DSA",q:"Insertion sort is most efficient when:",o:["Array is reverse sorted","Array is large","Array is nearly sorted or small","Array has duplicates"],a:2,tip:"Insertion sort: best on nearly sorted",e:"Insertion sort has O(n) best case on nearly sorted arrays (few shifts needed). Good for small n or mostly sorted data."},
{m:"DSA",q:"Search time in a balanced BST?",o:["O(n)","O(n²)","O(log n)","O(1)"],a:2,tip:"Balanced BST search = O(log n)",e:"Each comparison eliminates half the tree. With height=log n, search is O(log n)."},
{m:"DSA",q:"In selection sort, each pass:",o:["Swaps adjacent elements","Finds minimum and places it at correct position","Builds a heap","Partitions around pivot"],a:1,tip:"Selection sort: find min each pass",e:"Selection sort finds the minimum of the unsorted portion and swaps it into the next sorted position."},
{m:"DSA",q:"DFS (Depth-First Search) uses which structure internally?",o:["Queue","Heap","Stack (or recursion)","Array"],a:2,tip:"DFS uses Stack",e:"DFS uses an explicit stack or recursion (implicit stack) to go deep before backtracking."},
{m:"DSA",q:"Which is NOT a property of a max-heap?",o:["Parent ≥ both children","Complete binary tree","Root is maximum","Left child > right child always"],a:3,tip:"Max-heap: no left>right rule",e:"Max-heap requires parent ≥ children. There is NO ordering between siblings. Left > right is NOT required."},
{m:"DSA",q:"Space complexity of merge sort?",o:["O(1)","O(log n)","O(n)","O(n log n)"],a:2,tip:"Merge sort needs O(n) extra space",e:"Merge step needs temporary arrays totalling O(n) space. Unlike quicksort which is in-place."},
{m:"DSA",q:"Best hash function for integer keys?",o:["h(k)=k mod m where m is prime","h(k)=k*k mod m","h(k)=k+1","h(k)=0"],a:0,tip:"Modulo prime for uniform distribution",e:"h(k) = k mod m with prime m distributes keys uniformly, minimizing clustering and collisions."},
{m:"DSA",q:"In a circular linked list, the last node's 'next' points to:",o:["NULL","Itself","The first node (head)","Previous node"],a:2,tip:"Circular: last → first",e:"In a circular linked list, the last node's next pointer points back to the head, forming a cycle."},
{m:"DSA",q:"Worst-case time for searching in a hash table with chaining?",o:["O(1)","O(log n)","O(n)","O(n²)"],a:2,tip:"Hash worst case = O(n)",e:"If all n keys hash to the same bucket, the chain has length n — search is O(n). Average case is O(1+α) where α=load factor."},
{m:"DSA",q:"Minimum nodes in AVL tree of height 3?",o:["4","6","7","8"],a:2,tip:"N(h)=N(h-1)+N(h-2)+1",e:"N(0)=1, N(1)=2, N(2)=N(1)+N(0)+1=4, N(3)=N(2)+N(1)+1=7."},
{m:"DSA",q:"Which sorting algorithm is stable?",o:["Quick sort","Heap sort","Merge sort","Selection sort"],a:2,tip:"Merge sort is stable",e:"Stable: equal elements maintain original relative order. Merge sort is stable. Quick sort and heap sort are generally NOT stable."},
{m:"DSA",q:"Time to find an element in an unsorted array?",o:["O(1)","O(log n)","O(n)","O(n²)"],a:2,tip:"Linear search = O(n)",e:"Must potentially check every element in an unsorted array. Worst case: O(n)."},
{m:"DSA",q:"What is a leaf node?",o:["Node with two children","Node with no children","Root node","Node at level 1"],a:1,tip:"Leaf = no children",e:"A leaf (external) node has no children. Terminal node of the tree."},
{m:"DSA",q:"Quick sort uses which algorithmic paradigm?",o:["Dynamic programming","Divide and conquer","Greedy","Backtracking"],a:1,tip:"Quick sort: divide & conquer",e:"Quick sort: pick pivot, partition (divide), recursively sort partitions (conquer)."},
{m:"DSA",q:"Pop from empty stack causes:",o:["Returns 0","Returns NULL","Stack underflow","Stack overflow"],a:2,tip:"Empty stack pop = underflow",e:"Popping from an empty stack = stack underflow. Must check isEmpty() before popping."},
{m:"DSA",q:"Time complexity to build a binary heap from n elements (Floyd's method)?",o:["O(n log n)","O(n)","O(log n)","O(n²)"],a:1,tip:"Build heap = O(n)",e:"Floyd's heapify-from-bottom takes O(n) total — most nodes are near the bottom and need few swaps."},
{m:"DSA",q:"Which operation removes the minimum from a min-heap?",o:["dequeue","pop","extract-min","delete-root"],a:2,tip:"extract-min from heap",e:"extract-min removes root (minimum), replaces with last element, then sifts down. O(log n)."},
{m:"DSA",q:"What is the maximum number of nodes at level k of a binary tree (root = level 0)?",o:["k","2k","2^k","k²"],a:2,tip:"Level k max nodes = 2^k",e:"Level 0 (root)=1=2⁰, level 1=2=2¹, level k=2^k (all nodes have 2 children)."},
{m:"DSA",q:"Given pointer to a node in a doubly linked list, deletion takes:",o:["O(n)","O(log n)","O(1)","O(n²)"],a:2,tip:"DLL deletion with pointer = O(1)",e:"With prev and next pointers available, deletion only requires unlinking: prev.next=next, next.prev=prev. O(1)."},
{m:"DSA",q:"Which traversal is used to safely delete all nodes of a tree?",o:["Pre-order","In-order","Post-order","Level-order"],a:2,tip:"Post-order for tree deletion",e:"Post-order (Left-Right-Root) deletes children before parent, avoiding dangling references to deleted nodes."},
{m:"DSA",q:"What is a priority queue?",o:["Queue where last item has priority","Queue where highest priority item is dequeued first","Queue with two ends","Sorted array"],a:1,tip:"Priority queue: highest priority first",e:"Priority queue dequeues the element with highest (or lowest) priority first, regardless of insertion order. Usually implemented with a heap."},
{m:"DSA",q:"What is Big-O notation used for?",o:["Exact runtime in seconds","Upper bound on algorithm's growth rate","Lower bound on best case","Memory usage only"],a:1,tip:"Big-O = upper bound on growth",e:"Big-O describes the worst-case upper bound on how an algorithm's time (or space) grows with input size n."},
{m:"DSA",q:"Sequential search on a sorted array can terminate early when:",o:["First element found","Current element > target","Array half checked","Prime index reached"],a:1,tip:"Early termination on sorted array",e:"If current element > target, target can't appear later (array is sorted). Safe to stop and return 'not found'."},

// ── EMBEDDED OS (50) ──
{m:"OS",q:"What is a process?",o:["A program stored on disk","A program in execution with its own resources","A system call","An OS service"],a:1,tip:"Process = program in execution",e:"A process is a running instance of a program. It has its own PCB, address space, stack, heap, and CPU state."},
{m:"OS",q:"What does PCB (Process Control Block) contain?",o:["Only source code","Process state, registers, PID, memory maps, open files","File data","Network sockets only"],a:1,tip:"PCB stores all process info",e:"PCB stores everything needed to resume a process: PID, state, PC, registers, memory maps, open file descriptors, priority, etc."},
{m:"OS",q:"What is context switching?",o:["Switching file contexts","Saving current process state to PCB and loading another process's state","Changing display","Switching network connections"],a:1,tip:"Context switch = save+load PCB",e:"Context switching: save current process's registers/PC to its PCB, then load another process's PCB to resume it. Has overhead."},
{m:"OS",q:"Which scheduling algorithm can cause starvation of low-priority processes?",o:["Round Robin","FCFS","Priority Scheduling","SJF"],a:2,tip:"Priority scheduling → starvation",e:"In priority scheduling, if high-priority processes keep arriving, low-priority ones may never execute. Fix: aging (raise priority over time)."},
{m:"OS",q:"What is a mutex?",o:["A process type","Synchronization primitive for mutual exclusion — only one thread at a time","Memory allocation function","An interrupt type"],a:1,tip:"Mutex = mutual exclusion lock",e:"Mutex allows only one thread to enter a critical section. Unlike semaphore, only the locking thread can unlock it (ownership)."},
{m:"OS",q:"What is a semaphore?",o:["CPU register","Integer synchronization variable with atomic wait(P) and signal(V) operations","File system type","Scheduler algorithm"],a:1,tip:"Semaphore: P/V operations",e:"Semaphore: wait(P) decrements (blocks if 0), signal(V) increments (wakes waiter). Binary semaphore≈mutex, counting semaphore manages resources."},
{m:"OS",q:"What are the four Coffman conditions for deadlock?",o:["Mutual exclusion, Hold-and-wait, No preemption, Circular wait","Priority, Starvation, Timeout, Livelock","Busy-wait, Blocking, Yielding, Sleeping","None of these"],a:0,tip:"Coffman conditions",e:"All 4 must hold for deadlock: (1) Mutual exclusion, (2) Hold-and-wait, (3) No preemption, (4) Circular wait. Breaking any one prevents deadlock."},
{m:"OS",q:"What is the difference between a pipe and a FIFO (named pipe)?",o:["Pipes are faster","FIFO has a filesystem name; pipe is anonymous (related processes only)","Pipes support bidirectional I/O","FIFOs are for threads"],a:1,tip:"FIFO = named pipe",e:"Pipe: anonymous, only parent-child/related processes. FIFO: has a pathname in filesystem, usable by unrelated processes."},
{m:"OS",q:"What is virtual memory?",o:["Extra physical RAM","OS technique giving processes illusion of more memory using disk (swap)","GPU memory","Cache memory"],a:1,tip:"Virtual memory uses disk as extension",e:"Virtual memory maps virtual addresses to physical RAM (or swap space on disk). Allows processes to use more memory than physically available."},
{m:"OS",q:"What is thrashing?",o:["CPU overheating","Process spending more time paging in/out than actually executing","Disk fragmentation","Network congestion"],a:1,tip:"Thrashing = paging overhead > execution",e:"Thrashing: working set doesn't fit in RAM → constant page faults → CPU mostly doing I/O (paging) instead of executing code. Utilization collapses."},
{m:"OS",q:"What does fork() return to the parent process?",o:["0","PID of child process","-1","PID of parent"],a:1,tip:"fork() returns child PID to parent",e:"fork(): returns child PID to parent, 0 to child, -1 on failure. Creates an almost identical copy of the calling process."},
{m:"OS",q:"What is shared memory IPC?",o:["Kernel message buffer","Multiple processes map the same physical memory region directly","File-based communication","Socket connection"],a:1,tip:"Shared memory: fastest IPC",e:"Shared memory lets processes communicate by reading/writing the same memory region. Fastest IPC — no kernel copies after setup. Needs synchronization."},
{m:"OS",q:"OSI Layer 3 (Network layer) is responsible for:",o:["Framing","Routing and logical addressing (IP)","End-to-end reliability","Session management"],a:1,tip:"Layer 3 = Network = routing",e:"Layer 3 (Network): IP addressing and routing packets between different networks. IP protocol lives here."},
{m:"OS",q:"Which system call creates a new process in Linux?",o:["exec()","new()","fork()","spawn()"],a:2,tip:"fork() creates child process",e:"fork() creates a child by duplicating the parent. The child then uses exec() to load a different program if needed."},
{m:"OS",q:"What does an inode store in Unix file system?",o:["File name","File metadata: permissions, size, timestamps, data block pointers","File contents","Directory listing"],a:1,tip:"inode = metadata, not filename",e:"inode stores file metadata: owner, permissions, size, timestamps, block pointers. The filename is in the directory entry, not the inode."},
{m:"OS",q:"TCP vs UDP: TCP provides:",o:["Higher speed with no overhead","Reliable, ordered, error-checked delivery with connection setup","Connectionless transmission","Broadcast support only"],a:1,tip:"TCP: reliable ordered delivery",e:"TCP: 3-way handshake, sequence numbers, ACKs, retransmission = reliable ordered delivery. UDP: connectionless, faster, no guarantee."},
{m:"OS",q:"What is a monitor (in OS synchronization)?",o:["A display device","High-level construct with mutex + condition variables encapsulating shared data","Type of semaphore","CPU scheduling algorithm"],a:1,tip:"Monitor: high-level sync",e:"Monitor encapsulates shared data + mutex + condition variables. Provides structured synchronization. Java's synchronized keyword implements monitors."},
{m:"OS",q:"What is paging in memory management?",o:["Reading pages sequentially","Dividing virtual and physical memory into fixed-size blocks (pages/frames)","Sorting memory regions","OS boot process"],a:1,tip:"Paging: fixed-size virtual→physical",e:"Paging divides virtual memory into pages, physical into frames of equal size. Page table maps virtual pages to physical frames. Eliminates external fragmentation."},
{m:"OS",q:"How does a system call differ from a library call?",o:["Library calls are deprecated","System call switches to kernel mode; library call stays in user mode","No difference","System calls are faster"],a:1,tip:"System call → kernel mode switch",e:"System call: CPU switches to kernel mode (expensive context switch). Library call: pure user-space function. E.g., printf (library) internally calls write() (system call)."},
{m:"OS",q:"What is a zombie process?",o:["Malicious process","Completed process whose exit status wasn't collected by parent","Background daemon","Sleeping process"],a:1,tip:"Zombie = dead but not reaped",e:"Zombie: process finished but stays in process table because parent hasn't called wait()/waitpid() to collect exit status. Cleaned up when parent calls wait()."},
{m:"OS",q:"Correct sequence for TCP server socket setup?",o:["connect→bind→listen→accept","socket→bind→listen→accept","socket→listen→bind→accept","bind→socket→listen→accept"],a:1,tip:"socket→bind→listen→accept",e:"TCP server: socket() create socket → bind() assign address/port → listen() mark as passive → accept() wait for client."},
{m:"OS",q:"In Linux, the 'nice' value controls:",o:["Process name","CPU scheduling priority (-20=highest, +19=lowest)","Memory limit","File descriptor limit"],a:1,tip:"nice value = priority adjustment",e:"Nice value: -20 (highest priority) to +19 (lowest). Lower nice = more CPU time. Users can increase nice; only root can decrease (make higher priority)."},
{m:"OS",q:"What is segmentation in memory management?",o:["Fixed-size memory pages","Variable-size logical segments (code, data, stack, heap) with base+limit","Same as paging","Hardware interrupt handling"],a:1,tip:"Segmentation: variable-size logical sections",e:"Segmentation divides process into logical segments of variable size, each with a base address and limit. Allows separate protection for code, data, stack."},
{m:"OS",q:"What does wait() system call do?",o:["Sleeps parent forever","Blocks parent until child terminates and collects exit status (reaps zombie)","Creates new child","Sends signal"],a:1,tip:"wait() reaps child zombie",e:"wait() blocks until a child terminates, collects its exit status, and removes it from process table (prevents zombie). Returns child's PID."},
{m:"OS",q:"Which IPC is fastest for same-machine communication?",o:["TCP sockets","Named pipes","Shared memory","Message queues"],a:2,tip:"Shared memory = fastest IPC",e:"Shared memory: after shmget/shmat setup, communication is just memory access — no kernel involvement per-operation, no copying."},
{m:"OS",q:"What is the TLB (Translation Lookaside Buffer)?",o:["Buffer for disk reads","Hardware cache for recent virtual-to-physical address translations","Network buffer","DMA buffer"],a:1,tip:"TLB caches page table entries",e:"TLB is a small, fast hardware cache of recent virtual→physical translations. Without TLB: 2 memory accesses per read (page table + data). With TLB: ~1."},
{m:"OS",q:"TCP and UDP operate at which OSI layer?",o:["Layer 2 (Data Link)","Layer 3 (Network)","Layer 4 (Transport)","Layer 5 (Session)"],a:2,tip:"TCP/UDP = Layer 4 Transport",e:"Layer 4 (Transport) provides end-to-end communication: TCP (reliable) and UDP (unreliable fast) both operate here."},
{m:"OS",q:"kill() system call in Linux sends:",o:["Only SIGKILL signal","Any signal to a specified process","Terminates process immediately","Creates a new process"],a:1,tip:"kill(pid, sig) sends any signal",e:"Despite the name, kill(pid, signal) can send ANY signal (SIGTERM, SIGUSR1, SIGSTOP, etc.) to a process. SIGKILL=9 is just one option."},
{m:"OS",q:"Banker's Algorithm is used for:",o:["CPU scheduling","Deadlock avoidance (checks if state remains safe)","Memory compaction","File allocation"],a:1,tip:"Banker's = deadlock avoidance",e:"Banker's Algorithm: before granting a resource, check if resulting state is 'safe' (all processes can eventually complete). Refuses unsafe requests."},
{m:"OS",q:"What does exec() do after fork()?",o:["Creates another child","Replaces current process image with new program","Terminates parent","Forks again"],a:1,tip:"exec() replaces process image",e:"exec() family: replaces calling process's code, data, heap, stack with new program. PID stays same. Used after fork() to run different program."},
{m:"OS",q:"What is the shell's role in an OS?",o:["Directly manages hardware","Command interpreter — interface between user and OS services","Allocates physical memory","Handles hardware interrupts"],a:1,tip:"Shell = command interpreter",e:"Shell (bash, sh, zsh) interprets user commands, invokes system calls, manages processes, and provides scripting. Bridge between user and kernel."},
{m:"OS",q:"Which memory segment grows downward in a typical process?",o:["Code segment (.text)","Data segment (.data)","Heap","Stack"],a:3,tip:"Stack grows downward",e:"Stack grows from high to low addresses (downward). Heap grows upward. They grow towards each other — collision = stack overflow."},
{m:"OS",q:"In Round Robin scheduling, what is a 'time quantum'?",o:["Process priority","Maximum CPU time slice given to each process","Memory allocation unit","I/O wait time"],a:1,tip:"Round Robin: time quantum",e:"Round Robin gives each process a fixed time quantum (slice). When it expires, process preempted and moved to back of queue. Fair, good for time-sharing."},
{m:"OS",q:"What are pipes used for in Linux?",o:["Network communication","Inter-process communication via a unidirectional byte stream","File encryption","Memory sharing"],a:1,tip:"Pipe: IPC byte stream",e:"Pipe (|) creates a unidirectional byte stream: output of one process feeds as input to another. E.g., ls | grep .c"},
{m:"OS",q:"What is the OSI Layer 7?",o:["Transport","Session","Presentation","Application"],a:3,tip:"Layer 7 = Application",e:"OSI Layer 7 (Application): HTTP, FTP, SMTP, DNS, SSH. Provides network services directly to applications."},
{m:"OS",q:"What is a page fault?",o:["Hardware error","Access to virtual page not currently in physical RAM → OS loads it from disk","Wrong page permissions","CPU cache miss"],a:1,tip:"Page fault: page not in RAM",e:"Page fault: CPU accesses virtual address whose page is not in RAM. OS handles it: find page on disk, load into a free frame, update page table, resume."},
{m:"OS",q:"What is an orphan process?",o:["Process without file descriptors","Process whose parent terminated before it","Zombie process","Background process"],a:1,tip:"Orphan = parent died first",e:"Orphan process: parent died before child. Linux re-parents orphans to init (PID 1) which will call wait() for them."},
{m:"OS",q:"Which signal is used to gracefully terminate a process?",o:["SIGKILL (9)","SIGTERM (15)","SIGSTOP","SIGHUP"],a:1,tip:"SIGTERM = graceful termination",e:"SIGTERM (15): polite termination request — process can catch it and clean up. SIGKILL (9): force kill — cannot be caught or ignored."},
{m:"OS",q:"What does 'lseek()' system call do?",o:["Creates new file","Repositions file offset (seek position)","Links files","Locks file"],a:1,tip:"lseek = reposition file offset",e:"lseek(fd, offset, whence) repositions the file offset for the next read/write. SEEK_SET=from start, SEEK_CUR=from current, SEEK_END=from end."},
{m:"OS",q:"IPC message queues allow processes to:",o:["Share memory directly","Send structured messages to a kernel-managed queue","Create child processes","Access hardware ports"],a:1,tip:"Message queue: structured messages",e:"Message queues: kernel-managed queue where processes post/receive typed messages. More structured than pipes; messages can be received by type."},
{m:"OS",q:"What is the purpose of the OS file system?",o:["Manage CPU scheduling","Organize and manage persistent data storage (files, directories, permissions)","Handle interrupts","Manage RAM allocation"],a:1,tip:"File system = persistent storage management",e:"File system organizes data on storage devices into files and directories, manages allocation, permissions, metadata (inodes), and provides APIs."},

// ── MCU & RISC-V (50) ──
{m:"MCU",q:"How many general-purpose registers does ARM Cortex-M have (R0–R12)?",o:["8","10","13","16"],a:2,tip:"Cortex-M: R0–R12 = 13 GPRs",e:"ARM Cortex-M has R0–R12 (13 GPRs) + R13(SP) + R14(LR) + R15(PC) + xPSR = 17 registers total. R0–R12 are general-purpose."},
{m:"MCU",q:"What is NVIC in ARM Cortex-M?",o:["Memory controller","Nested Vectored Interrupt Controller — manages interrupt priorities and nesting","Clock generator","Debug interface"],a:1,tip:"NVIC manages interrupts",e:"NVIC handles interrupt enable/disable, priority levels, pending status, and supports nested interrupts (higher priority can preempt lower)."},
{m:"MCU",q:"What is SysTick timer used for?",o:["PWM generation","UART baud rate generation","Periodic OS tick interrupt for RTOS","Watchdog reset"],a:2,tip:"SysTick = OS tick timer",e:"SysTick is a 24-bit down-counter generating periodic interrupts. Used by RTOS (FreeRTOS, etc.) for task scheduling tick."},
{m:"MCU",q:"What is bit-banding in ARM Cortex-M?",o:["Compress memory","Map each peripheral/SRAM bit to unique 32-bit word for atomic bit access","Speed up DMA","Encrypt memory"],a:1,tip:"Bit-banding = atomic bit access",e:"Bit-banding aliases each bit in SRAM/peripheral space to its own 32-bit word. Writing 1/0 to the alias atomically sets/clears the bit — no race conditions."},
{m:"MCU",q:"SPI uses how many wires for full-duplex?",o:["2","3","4","1"],a:2,tip:"SPI: 4 wires (SCLK,MOSI,MISO,CS)",e:"SPI: SCLK (clock), MOSI (Master Out Slave In), MISO (Master In Slave Out), CS/SS (Chip Select). Full-duplex simultaneous send/receive."},
{m:"MCU",q:"Standard I2C supports up to how many devices (7-bit address)?",o:["16","64","128 (112 usable)","256"],a:2,tip:"I2C 7-bit: 128 addresses",e:"7-bit I2C addressing: 2^7=128 addresses. Some are reserved (0x00, 0x78–0x7F), leaving ~112 usable device addresses."},
{m:"MCU",q:"PWM (Pulse Width Modulation) controls:",o:["Digital logic levels only","Analog devices by varying duty cycle of square wave","Clock frequency","Interrupt priority"],a:1,tip:"PWM: duty cycle control",e:"PWM varies the ON-time percentage (duty cycle) of a square wave. 0% duty=fully off, 100%=fully on, 50%=half power. Used for motor control, LED brightness, DAC."},
{m:"MCU",q:"What is the Interrupt Vector Table (IVT)?",o:["RAM data table","Array of handler function addresses at start of memory, indexed by exception number","Register file","DMA descriptor list"],a:1,tip:"IVT = array of handler addresses",e:"The vector table is an array at the start of flash (or RAM). Each entry is the address of the corresponding interrupt/exception handler (ISR)."},
{m:"MCU",q:"In UART, what does TX stand for?",o:["Transfer Register","Transmit — pin that sends data","Terminal eXchange","Time eXtension"],a:1,tip:"UART TX = transmit",e:"UART TX (Transmit) sends data as serial bits. RX (Receive) receives data. UART is asynchronous — no shared clock, baud rates must match."},
{m:"MCU",q:"DMA (Direct Memory Access) is used to:",o:["Perform arithmetic operations","Transfer data between memory/peripherals without CPU involvement","Generate clock signals","Manage power modes"],a:1,tip:"DMA: CPU-free data transfer",e:"DMA controller handles data transfers autonomously. CPU sets up the transfer and is free for other tasks. Used for UART, ADC, SPI, USB bulk transfers."},
{m:"MCU",q:"What resets the MCU if software doesn't periodically kick it?",o:["RTC timer","ADC timeout","Watchdog Timer (WDT)","SysTick"],a:2,tip:"Watchdog timer detects hangs",e:"Watchdog Timer: software must 'kick' (refresh) it within a timeout period. If it expires, WDT resets the MCU. Detects software hangs/crashes."},
{m:"MCU",q:"RISC-V privilege modes from highest to lowest?",o:["User→Supervisor→Machine","Machine→Supervisor→User","Hypervisor→Machine→User","Ring0→Ring1→Ring2"],a:1,tip:"RISC-V: M > S > U",e:"RISC-V: Machine mode (M) = highest, Supervisor (S) = OS kernel, User (U) = applications. All implementations must have M-mode."},
{m:"MCU",q:"RISC-V register x0 (zero) always contains:",o:["Stack pointer","Return address","Hardwired zero — reads always 0, writes ignored","Scratch value"],a:2,tip:"RISC-V x0 = hardwired zero",e:"x0 is hardwired to 0 in RISC-V. Any write to x0 is discarded. Used for no-ops (ADDI x0,x0,0) and discarding results."},
{m:"MCU",q:"C-DAC VEGA processor is based on which ISA?",o:["ARM Cortex-A","RISC-V","MIPS","x86"],a:1,tip:"VEGA = RISC-V based",e:"C-DAC's VEGA processor family is indigenously designed by India and based on the open RISC-V instruction set architecture."},
{m:"MCU",q:"What does GPIO stand for?",o:["General Processing I/O","General Purpose Input/Output","Global Port Interface Operations","Graphics Peripheral I/O"],a:1,tip:"GPIO = General Purpose I/O",e:"GPIO pins can be configured as digital inputs (read buttons, sensors) or digital outputs (drive LEDs, relays) under software control."},
{m:"MCU",q:"ARM Cortex profile for hard real-time applications?",o:["Cortex-A (Application)","Cortex-R (Real-time)","Cortex-M (Microcontroller)","Cortex-X (Extended)"],a:1,tip:"Cortex-R = Real-time profile",e:"Cortex-R: deterministic, low-latency response for hard real-time (automotive ABS, hard disk controllers). Cortex-A: high-performance OS. Cortex-M: microcontrollers."},
{m:"MCU",q:"What is CMSIS?",o:["Compiler optimization","Cortex Microcontroller Software Interface Standard — standardized ARM Cortex-M hardware APIs","Debug protocol","Circuit simulation tool"],a:1,tip:"CMSIS = ARM standardized APIs",e:"CMSIS provides standardized startup code, register definitions, DSP library, RTOS APIs for ARM Cortex-M. Improves code portability across vendors."},
{m:"MCU",q:"I2C Fast Mode speed is:",o:["100 kbps","400 kbps","1 Mbps","10 Mbps"],a:1,tip:"I2C: Standard=100k, Fast=400k",e:"I2C speeds: Standard=100kbps, Fast Mode=400kbps, Fast Mode+=1Mbps, High Speed=3.4Mbps."},
{m:"MCU",q:"PendSV exception in Cortex-M is used for:",o:["Hard fault handling","RTOS context switching (lowest-priority exception, pended by OS)","DMA completion","Timer overflow"],a:1,tip:"PendSV = RTOS context switch",e:"PendSV runs at lowest priority, after all ISRs complete. RTOS uses it for context switches — ensuring task switching doesn't interrupt other ISRs."},
{m:"MCU",q:"RISC-V ECALL instruction does what?",o:["External hardware interrupt","System call — transfers control to higher privilege mode","Memory fence (ordering)","Branch instruction"],a:1,tip:"ECALL = system call in RISC-V",e:"ECALL generates an environment call exception, transferring to M-mode (or S-mode). Used by U-mode applications to request OS services."},
{m:"MCU",q:"ADC (Analog to Digital Converter) converts:",o:["Analog voltage to digital binary number","Digital to analog","AC power to DC","Address to data"],a:0,tip:"ADC: analog → digital",e:"ADC samples analog voltage, compares against reference, outputs n-bit digital value. Resolution = 2^n levels. E.g., 12-bit ADC: 0–4095."},
{m:"MCU",q:"ARM register R14 is the:",o:["Stack Pointer","Link Register — stores return address for function calls","Program Counter","General scratch register"],a:1,tip:"R14 = LR (Link Register)",e:"When BL/BLX branches, R14 (LR) automatically stores PC+4 (return address). At function end, BX LR jumps back to caller."},
{m:"MCU",q:"What does MPU (Memory Protection Unit) do?",o:["Speed up memory access","Define memory regions with access permissions to prevent unauthorized access","Encrypt memory contents","Expand RAM size"],a:1,tip:"MPU: memory region protection",e:"MPU defines up to 8 regions with configurable permissions (read/write/execute, privileged/unprivileged). Prevents tasks from corrupting each other's memory."},
{m:"MCU",q:"CAN bus is primarily used in:",o:["Consumer home electronics","Automotive/industrial real-time control networks","Home WiFi","USB peripheral connections"],a:1,tip:"CAN bus: automotive/industrial",e:"CAN (Controller Area Network) is robust against EMI, supports multi-master, uses differential signaling. Standard in automotive (ECUs) and industrial automation."},
{m:"MCU",q:"RISC-V U-type instruction format is used for:",o:["Register-register ops (R-type)","Loads/stores","Instructions with 20-bit immediate (LUI, AUIPC)","Branch instructions"],a:2,tip:"U-type: 20-bit immediate",e:"U-type has a 20-bit immediate field. LUI (Load Upper Immediate) loads 20-bit immediate into upper 20 bits of register. AUIPC adds it to PC."},
{m:"MCU",q:"Difference between Sleep and Stop low-power modes (STM32)?",o:["Same power consumption","Sleep halts CPU only; Stop halts CPU+clocks, deeper power saving","Stop is lighter than Sleep","Sleep shuts off all peripherals"],a:1,tip:"Sleep vs Stop power modes",e:"Sleep: CPU halted, peripherals run, fast wake-up. Stop: CPU + most clocks off, much lower power but longer wake-up latency. Standby is deepest (RAM lost)."},
{m:"MCU",q:"SVCall (SVC) exception in Cortex-M is used for:",o:["Stack violation error","Supervisor Call — allows unprivileged code to request privileged OS services","Speed violation","Segment violation"],a:1,tip:"SVC = embedded system call",e:"SVC (Supervisor Call) is triggered by SVC instruction. Allows RTOS tasks (unprivileged) to call OS APIs (privileged) safely — the embedded equivalent of system calls."},
{m:"MCU",q:"SPI communication mode is determined by:",o:["Baud rate only","CPOL (clock polarity) and CPHA (clock phase) settings","CS pin polarity only","Data frame size"],a:1,tip:"SPI modes: CPOL + CPHA",e:"4 SPI modes: CPOL=0/1 (clock idle low/high) × CPHA=0/1 (sample on 1st/2nd edge). Both master and slave must use same mode."},
{m:"MCU",q:"SFR (Special Function Register) area contains:",o:["User application code","Peripheral control/status registers (GPIO, UART, ADC, DMA, timers)","OS kernel data","DMA buffers"],a:1,tip:"SFRs = peripheral registers",e:"SFRs are memory-mapped registers controlling on-chip peripherals. Writing to GPIOA_ODR register (SFR) directly drives GPIO pins."},
{m:"MCU",q:"RISC-V NOP is implemented as:",o:["Special NOP opcode","ADDI x0, x0, 0 (add 0 to x0, discard result)","MOV x0, x0","HALT instruction"],a:1,tip:"RISC-V NOP = ADDI x0,x0,0",e:"RISC-V has no dedicated NOP. Standard NOP is ADDI x0, x0, 0 — writes to x0 (discarded), no side effects, takes one cycle."},
{m:"MCU",q:"What is RTC (Real Time Clock) used for?",o:["CPU task scheduling","Maintaining current date/time even when main power off (battery backed)","Generating random numbers","Managing flash memory wear"],a:1,tip:"RTC = always-on clock",e:"RTC uses a low-power oscillator (32.768 kHz crystal) to keep accurate time. Runs on backup battery (coin cell) when main power is off."},
