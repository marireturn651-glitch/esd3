  --r:8px;--r2:12px;--r3:16px;
}
*{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;font-family:'Outfit',sans-serif;background:var(--bg);color:var(--txt);overflow-x:hidden}

/* ─── UTILITY ─── */
.hidden{display:none!important}
.flex{display:flex}.flex-col{flex-direction:column}.items-center{align-items:center}.justify-center{justify-content:center}.justify-between{justify-content:space-between}.gap1{gap:.5rem}.gap2{gap:1rem}.gap3{gap:1.5rem}.wrap{flex-wrap:wrap}
.w100{width:100%}.text-center{text-align:center}.bold{font-weight:700}
.muted{color:var(--txt2)}.dimmed{color:var(--txt3)}
.tag{padding:.2rem .7rem;border-radius:20px;font-size:.7rem;font-weight:700;letter-spacing:.5px;text-transform:uppercase}

/* ─── SCROLLBAR ─── */
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:var(--s1)}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}

/* ══════════════ SCREEN SYSTEM ══════════════ */
.screen{display:none;min-height:100vh}
.screen.active{display:flex}

/* ══════════════ LANDING ══════════════ */
#s-land{flex-direction:column;align-items:center;justify-content:center;padding:2rem;min-height:100vh;background:radial-gradient(ellipse at 30% 20%,#0a1a3a 0%,var(--bg) 60%)}
.brand{text-align:center;margin-bottom:2.5rem}
.brand-logo{font-size:3.2rem;font-weight:800;letter-spacing:6px;background:linear-gradient(135deg,var(--acc),#a78bfa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1}
.brand-sub{font-size:.8rem;color:var(--txt3);letter-spacing:3px;margin-top:.4rem;text-transform:uppercase}
.brand-bar{width:60px;height:3px;background:linear-gradient(90deg,var(--acc),#a78bfa);border-radius:2px;margin:.8rem auto 0}

.form-card{background:var(--s1);border:1px solid var(--border);border-radius:var(--r3);padding:2.5rem;width:100%;max-width:460px;position:relative;overflow:hidden}
.form-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--acc),#a78bfa,var(--grn))}
.form-card h2{font-size:1.2rem;font-weight:700;margin-bottom:1.8rem}
.field{margin-bottom:1.3rem}
.field label{display:block;font-size:.75rem;font-weight:600;color:var(--txt3);margin-bottom:.5rem;letter-spacing:.8px;text-transform:uppercase}
.field input,.field select{width:100%;background:var(--s2);border:1.5px solid var(--border);border-radius:var(--r);padding:.75rem 1rem;color:var(--txt);font-family:'Outfit',sans-serif;font-size:.95rem;outline:none;transition:border-color .2s,box-shadow .2s}
.field input:focus,.field select:focus{border-color:var(--acc);box-shadow:0 0 0 3px rgba(79,158,255,.12)}
.field select option{background:var(--s2)}

.btn-primary{width:100%;padding:.9rem;background:linear-gradient(135deg,var(--acc),var(--acc2));color:#fff;font-family:'Outfit',sans-serif;font-size:1rem;font-weight:700;border:none;border-radius:var(--r);cursor:pointer;transition:opacity .2s,transform .1s;letter-spacing:.3px}
.btn-primary:hover{opacity:.9;transform:translateY(-1px)}
.btn-primary:active{transform:translateY(0)}

.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:.8rem;width:100%;max-width:460px;margin-top:1.5rem}
.kpi{background:var(--s1);border:1px solid var(--border);border-radius:var(--r2);padding:1rem;text-align:center}
.kpi-val{font-size:1.8rem;font-weight:800;color:var(--acc);line-height:1}
.kpi-lbl{font-size:.68rem;color:var(--txt3);margin-top:.2rem;text-transform:uppercase;letter-spacing:.5px}

/* ══════════════ INSTRUCTIONS ══════════════ */
#s-instr{flex-direction:column;align-items:center;justify-content:center;padding:2rem;background:var(--bg)}
.instr-card{background:var(--s1);border:1px solid var(--border);border-radius:var(--r3);padding:2.5rem;width:100%;max-width:540px;position:relative}
.instr-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--grn),var(--acc))}
.instr-card h2{font-size:1.4rem;font-weight:800;margin-bottom:1.5rem;color:var(--acc)}
.instr-item{display:flex;align-items:flex-start;gap:.9rem;margin-bottom:1rem;font-size:.9rem;line-height:1.5}
.instr-icon{font-size:1.1rem;flex-shrink:0;margin-top:.05rem}
.instr-item em{color:var(--ylw);font-style:normal;font-weight:700}
.btn-go{margin-top:1.8rem;width:100%;padding:.9rem;background:linear-gradient(135deg,var(--grn),var(--grn2));color:#fff;font-family:'Outfit',sans-serif;font-size:1.05rem;font-weight:800;border:none;border-radius:var(--r);cursor:pointer;transition:opacity .2s,transform .1s}
.btn-go:hover{opacity:.9;transform:translateY(-1px)}

/* ══════════════ EXAM ══════════════ */
#s-exam{display:none;height:100vh;overflow:hidden}
#s-exam.active{display:grid;grid-template-columns:1fr 300px}

.exam-left{display:flex;flex-direction:column;height:100vh;overflow:hidden}

/* Top bar */
.topbar{flex-shrink:0;display:flex;align-items:center;justify-content:space-between;padding:.7rem 1.5rem;background:var(--s1);border-bottom:1px solid var(--border)}
.topbar-left{display:flex;align-items:center;gap:1rem}
.q-num{font-size:.85rem;color:var(--txt2)}
.q-num strong{color:var(--txt);font-size:1rem}
.mod-badge{padding:.22rem .65rem;border-radius:20px;font-size:.7rem;font-weight:700;letter-spacing:.5px}
.topbar-right{display:flex;align-items:center;gap:1.2rem}
.score-live{font-size:.85rem;color:var(--txt2)}
.score-live strong{color:var(--acc);font-size:1rem}
.timer{font-family:'JetBrains Mono',monospace;font-size:1.6rem;font-weight:600;color:var(--grn);min-width:70px;text-align:right}
.timer.warn{color:var(--ylw)}
.timer.danger{color:var(--red);animation:blink 1s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.4}}

/* Question body */
.q-body{flex:1;overflow-y:auto;padding:1.8rem 2rem}
.q-header{display:flex;align-items:center;gap:.6rem;margin-bottom:1rem}
.q-badge{font-size:.72rem;font-weight:700;padding:.2rem .6rem;border-radius:5px;background:var(--b1);border:1px solid var(--border);color:var(--txt3)}
.q-text{font-size:1rem;line-height:1.75;color:var(--txt);margin-bottom:1.2rem;font-weight:500}
pre.code{background:#050a12;border:1px solid var(--border);border-radius:var(--r);padding:1rem 1.2rem;font-family:'JetBrains Mono',monospace;font-size:.8rem;line-height:1.7;margin-bottom:1.2rem;overflow-x:auto;border-left:3px solid var(--acc)}
.kw{color:#79b8ff}.str{color:#9ecbff}.num{color:#79dcaa}.cmt{color:#586069;font-style:italic}.pp{color:#b392f0}.fn{color:#b392f0}
.opts{display:grid;gap:.65rem;margin-bottom:1rem}
.opt{display:flex;align-items:center;gap:.9rem;background:var(--s2);border:1.5px solid var(--border);border-radius:var(--r2);padding:.85rem 1.1rem;cursor:pointer;transition:all .15s;font-size:.9rem;color:var(--txt)}
.opt:hover:not(.disabled){border-color:var(--acc);background:var(--b1);transform:translateX(3px)}
.opt.disabled{cursor:default}
.opt.correct{border-color:var(--grn)!important;background:rgba(46,204,113,.1)!important;color:var(--grn)!important}
.opt.wrong{border-color:var(--red)!important;background:rgba(231,76,60,.1)!important;color:var(--red)!important}
.opt.reveal{border-color:var(--grn)!important;background:rgba(46,204,113,.06)!important}
.opt-circle{width:28px;height:28px;min-width:28px;border-radius:50%;background:var(--b1);border:1.5px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:700;transition:all .15s}
.opt.correct .opt-circle{background:var(--grn);border-color:var(--grn);color:#000}
.opt.wrong .opt-circle{background:var(--red);border-color:var(--red);color:#fff}
.opt.reveal .opt-circle{background:var(--grn);border-color:var(--grn);color:#000}
.explanation{background:rgba(79,158,255,.07);border-left:3px solid var(--acc);padding:1rem 1.2rem;border-radius:0 var(--r) var(--r) 0;font-size:.85rem;line-height:1.6;margin-top:.5rem}
.exp-title{font-size:.72rem;font-weight:700;color:var(--acc);margin-bottom:.4rem;text-transform:uppercase;letter-spacing:.5px}

/* Bottom nav */
.exam-nav{flex-shrink:0;display:flex;align-items:center;justify-content:space-between;gap:.6rem;padding:.8rem 1.2rem;background:var(--s1);border-top:1px solid var(--border)}
.nav-group{display:flex;gap:.5rem}
.btn-nav{padding:.5rem 1rem;border-radius:var(--r);border:1px solid var(--border);background:var(--s2);color:var(--txt2);cursor:pointer;font-family:'Outfit',sans-serif;font-size:.82rem;font-weight:600;transition:all .15s}
.btn-nav:hover{border-color:var(--acc);color:var(--acc)}
.btn-nav.accent{background:linear-gradient(135deg,var(--acc),var(--acc2));color:#fff;border:none}
.btn-nav.accent:hover{opacity:.88}
.btn-nav.danger{background:linear-gradient(135deg,var(--red),var(--red2));color:#fff;border:none}
.btn-nav.danger:hover{opacity:.88}
.btn-nav.skip{border-color:var(--ylw);color:var(--ylw)}
.btn-nav.skip:hover{background:rgba(241,196,15,.1)}

/* ══════════════ SIDEBAR ══════════════ */
.sidebar{background:var(--s1);border-left:1px solid var(--border);display:flex;flex-direction:column;height:100vh;overflow:hidden}
.sb-section{padding:.9rem;border-bottom:1px solid var(--border);flex-shrink:0}
.sb-title{font-size:.7rem;font-weight:700;color:var(--txt3);text-transform:uppercase;letter-spacing:.8px;margin-bottom:.7rem}
.mod-filter{display:flex;gap:.3rem;flex-wrap:wrap}
.mf-btn{padding:.22rem .55rem;border-radius:5px;font-size:.7rem;font-weight:700;cursor:pointer;border:1.5px solid transparent;transition:all .15s;background:transparent}
.mf-btn.active{background:rgba(255,255,255,.08)}
.mf-btn[data-m="ALL"]{color:var(--txt2);border-color:var(--border2)}
.mf-btn[data-m="EC"]{color:var(--ec);border-color:var(--ec)}
.mf-btn[data-m="DSA"]{color:var(--dsa);border-color:var(--dsa)}
.mf-btn[data-m="OS"]{color:var(--os);border-color:var(--os)}
.mf-btn[data-m="MCU"]{color:var(--mcu);border-color:var(--mcu)}
.prog-rows{margin-top:.7rem;display:flex;flex-direction:column;gap:.4rem}
.pr{display:flex;align-items:center;gap:.5rem}
.pr-lbl{font-size:.68rem;font-weight:700;width:30px;flex-shrink:0}
.pr-bar{flex:1;height:5px;background:var(--s3);border-radius:3px;overflow:hidden}
.pr-fill{height:100%;border-radius:3px;transition:width .4s}
.pr-num{font-size:.65rem;color:var(--txt3);width:32px;text-align:right;flex-shrink:0}
.dot-grid{flex:1;overflow-y:auto;padding:.8rem;display:grid;grid-template-columns:repeat(8,1fr);gap:.3rem;align-content:start}
.dot{width:26px;height:26px;border-radius:5px;border:1.5px solid var(--border);background:var(--s2);font-size:.65rem;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--txt3);transition:all .12s;font-weight:600}
.dot:hover{border-color:var(--acc)}
.dot.cur{border-color:var(--acc)!important;color:var(--acc)!important;background:var(--b1)!important}
.dot.ok{background:var(--grn)!important;border-color:var(--grn)!important;color:#000!important}
.dot.ng{background:var(--red)!important;border-color:var(--red)!important;color:#fff!important}
.dot.sk{background:var(--ylw)!important;border-color:var(--ylw)!important;color:#000!important}
.dot.hide{display:none}
.sb-legend{padding:.6rem .9rem;border-top:1px solid var(--border);flex-shrink:0;display:flex;gap:.8rem;flex-wrap:wrap}
.leg{display:flex;align-items:center;gap:.3rem;font-size:.65rem;color:var(--txt3)}
.leg-sq{width:8px;height:8px;border-radius:2px;flex-shrink:0}

/* ══════════════ RESULT ══════════════ */
#s-result{flex-direction:column;overflow-y:auto;padding:2rem;background:var(--bg);min-height:100vh}
.result-inner{max-width:680px;margin:0 auto;width:100%}
.res-hero{background:var(--s1);border:1px solid var(--border);border-radius:var(--r3);padding:2.5rem 2rem;text-align:center;margin-bottom:1.2rem;position:relative;overflow:hidden}
.res-hero::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--acc),var(--pur),var(--grn))}
.res-emoji{font-size:3.5rem;line-height:1;margin-bottom:.5rem}
.res-pct{font-size:4.5rem;font-weight:800;line-height:1;background:linear-gradient(135deg,var(--acc),#a78bfa);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.res-msg{color:var(--txt2);margin:.5rem 0 1.5rem;font-size:.95rem}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.7rem}
.stat{background:var(--s2);border-radius:var(--r);padding:.9rem;text-align:center;border:1px solid var(--border)}
.stat-val{font-size:1.8rem;font-weight:800;line-height:1}
.stat-lbl{font-size:.65rem;color:var(--txt3);margin-top:.2rem;text-transform:uppercase;letter-spacing:.5px}

.res-section{background:var(--s1);border:1px solid var(--border);border-radius:var(--r3);padding:1.5rem;margin-bottom:1.2rem}
.res-section h3{font-size:.95rem;font-weight:700;margin-bottom:1.2rem;display:flex;align-items:center;gap:.5rem}
.mb-row{margin-bottom:.9rem}
.mb-top{display:flex;justify-content:space-between;font-size:.82rem;margin-bottom:.3rem}
.mb-top span:first-child{font-weight:700}
.mb-bar{height:7px;background:var(--s3);border-radius:4px;overflow:hidden}
.mb-fill{height:100%;border-radius:4px;transition:width .6s .1s}

/* Leaderboard */
.podium{display:flex;justify-content:center;align-items:flex-end;gap:.8rem;margin-bottom:1.5rem;padding:.5rem 0}
.pod-slot{flex:1;max-width:120px;text-align:center;display:flex;flex-direction:column;align-items:center}
.pod-medal{font-size:1.4rem;line-height:1;margin-bottom:.3rem}
.pod-av{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:800;margin-bottom:.4rem;border:2px solid transparent}
.pod-name{font-size:.72rem;font-weight:700;word-break:break-all;max-width:100px}
.pod-pct{font-size:.65rem;color:var(--txt3);margin-top:.1rem}
.pod-base{border-radius:4px 4px 0 0;margin-top:.4rem;width:100%}
.lb-table{width:100%;border-collapse:collapse;font-size:.8rem}
.lb-table th{padding:.4rem .6rem;text-align:left;color:var(--txt3);border-bottom:1px solid var(--border);font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px}
.lb-table td{padding:.5rem .6rem;border-bottom:1px solid rgba(255,255,255,.04)}
.lb-table tr.you td{background:rgba(79,158,255,.08);color:var(--acc)}
.you-tag{background:var(--acc);color:#000;padding:.05rem .35rem;border-radius:3px;font-size:.6rem;font-weight:800;margin-left:.3rem}

.res-actions{display:flex;gap:.8rem;justify-content:center;flex-wrap:wrap;margin-top:.5rem}
.ra-btn{padding:.7rem 1.4rem;border-radius:var(--r);border:1.5px solid var(--border);background:var(--s2);color:var(--txt);cursor:pointer;font-family:'Outfit',sans-serif;font-size:.88rem;font-weight:700;transition:all .15s}
.ra-btn:hover{border-color:var(--acc);color:var(--acc)}
.ra-btn.primary{background:linear-gradient(135deg,var(--acc),var(--acc2));color:#fff;border:none}
.ra-btn.primary:hover{opacity:.88}

/* Confetti */
.cf{position:fixed;border-radius:2px;animation:cf-fall linear forwards;pointer-events:none;z-index:9999}
@keyframes cf-fall{to{transform:translateY(105vh) rotate(540deg);opacity:0}}

/* Mobile */
@media(max-width:640px){
  #s-exam.active{grid-template-columns:1fr}
  .sidebar{display:none}
  .kpi-row{grid-template-columns:repeat(2,1fr)}
  .stats-grid{grid-template-columns:repeat(2,1fr)}
  .q-body{padding:1.2rem}
}
</style>
</head>
<body>

<!-- ══ LANDING ══ -->
<div id="s-land" class="screen active">
  <div class="brand">
    <div class="brand-logo">CDAC ESD</div>
    <div class="brand-sub">Mock Exam Portal · CCE 2026 · PGCP-ESD</div>
    <div class="brand-bar"></div>
  </div>
  <div class="form-card">
    <h2>🎯 Start Practice Exam</h2>
    <div class="field">
      <label>Your Name</label>
      <input type="text" id="inp-name" placeholder="Enter your name..." autocomplete="off">
    </div>
    <div class="field">
      <label>Select Module</label>
      <select id="inp-mod">
        <option value="ALL">📚 All Modules — 200 Questions (90 min)</option>
        <option value="EC">🔵 Embedded C Programming — 50 Questions (30 min)</option>
        <option value="DSA">🟢 Data Structures & Algorithms — 50 Questions (30 min)</option>
        <option value="OS">🟡 Embedded Operating Systems — 50 Questions (30 min)</option>
        <option value="MCU">🟣 Microcontroller & RISC-V — 50 Questions (30 min)</option>
      </select>
    </div>
    <button class="btn-primary" id="btn-proceed">Proceed to Instructions →</button>
  </div>
  <div class="kpi-row">
    <div class="kpi"><div class="kpi-val">200</div><div class="kpi-lbl">Questions</div></div>
    <div class="kpi"><div class="kpi-val">4</div><div class="kpi-lbl">Modules</div></div>
    <div class="kpi"><div class="kpi-val">0</div><div class="kpi-lbl">Negative Marks</div></div>
    <div class="kpi"><div class="kpi-val" id="kpi-attempts">0</div><div class="kpi-lbl">Attempts</div></div>
  </div>
</div>

<!-- ══ INSTRUCTIONS ══ -->
<div id="s-instr" class="screen">
  <div class="instr-card">
    <h2>📋 Exam Instructions</h2>
    <div class="instr-item"><span class="instr-icon">⏱</span><span>Timer: <em>30 min per module</em> / <em>90 min</em> for All Modules. Auto-submits on timeout.</span></div>
    <div class="instr-item"><span class="instr-icon">✅</span><span>Marking: <em>+1 mark</em> for each correct answer</span></div>
    <div class="instr-item"><span class="instr-icon">❌</span><span><em>No negative marking</em> — wrong answers get 0 marks</span></div>
    <div class="instr-item"><span class="instr-icon">⏭</span><span>You can <em>Skip</em> questions and return to them later</span></div>
    <div class="instr-item"><span class="instr-icon">⌨</span><span>Keyboard: Press <em>1–4</em> to answer, <em>← →</em> for navigation</span></div>
    <div class="instr-item"><span class="instr-icon">💡</span><span>After each answer, a <em>detailed explanation</em> is shown</span></div>
    <div class="instr-item"><span class="instr-icon">🏆</span><span>Your result is saved to the <em>Leaderboard</em> after submission</span></div>
    <div class="instr-item"><span class="instr-icon">🔀</span><span>Answer options are <em>shuffled randomly</em> each attempt</span></div>
    <button class="btn-go" id="btn-start">🚀 Start Exam Now</button>
  </div>
</div>

<!-- ══ EXAM ══ -->
<div id="s-exam" class="screen">
  <!-- Left: question area -->
  <div class="exam-left">
    <div class="topbar">
      <div class="topbar-left">
        <span class="q-num">Q <strong id="qn-cur">1</strong> / <strong id="qn-tot">50</strong></span>
        <span class="mod-badge" id="qn-mod"></span>
      </div>
      <div class="topbar-right">
        <span class="score-live">Score: <strong id="score-live">0</strong></span>
        <span class="timer" id="timer">30:00</span>
      </div>
    </div>
    <div class="q-body" id="q-body"></div>
    <div class="exam-nav">
      <div class="nav-group">
        <button class="btn-nav" id="btn-prev">◀ Prev</button>
        <button class="btn-nav skip" id="btn-skip">Skip ⏭</button>
        <button class="btn-nav accent" id="btn-next">Next ▶</button>
      </div>
      <button class="btn-nav danger" id="btn-submit">Submit Exam ✓</button>
    </div>
  </div>
  <!-- Right: sidebar -->
  <div class="sidebar">
    <div class="sb-section">
      <div class="sb-title">Module Filter</div>
      <div class="mod-filter">
        <button class="mf-btn active" data-m="ALL">ALL</button>
        <button class="mf-btn" data-m="EC">EC</button>
        <button class="mf-btn" data-m="DSA">DSA</button>
        <button class="mf-btn" data-m="OS">OS</button>
